{
  "name": "geo-capture",
  "version": "0.1.5",
  "description": "Fast location capture for travel journals in Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "audit": "npm audit",
    "check": "npm run build && npm run audit"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "travel",
    "maps",
    "geolocation"
  ],
  "author": "fab34",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
